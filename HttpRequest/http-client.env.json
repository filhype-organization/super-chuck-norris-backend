{
  "joke-dev": {
    "host": "http://localhost",
    "port": "8080",
    "path": "/api/jokes/v1",
    "Security": {
      "Auth": {
        "oauth2": {
          "Token URL": "http://localhost:8180/realms/app/protocol/openid-connect/token",
          "Client ID": "back",
          "Client Secret": "{{clientSecret}}",
          "Grant Type": "Client Credentials",
          "Type": "OAuth2",
          "Acquire Automatically": true
        }
      }
    }
  },
  "keycloak-dev": {
    "host": "http://localhost",
    "port": "8180",
    "add_user_path": "admin/realms/app/users",
    "get_roles_path": "admin/realms/app/roles",
    "get_users_path": "admin/realms/app/users",
    "assign_role_path": "admin/realms/app/users/{{userId}}/role-mappings/realm",
    "Security": {
        "Auth": {
            "oauth2": {
              "Token URL": "http://localhost:8180/realms/master/protocol/openid-connect/token",
              "Client ID": "admin-cli",
              "Grant Type": "Password",
              "Username": "{{username}}",
              "Password": "{{password}}",
              "Type": "OAuth2",
              "Acquire Automatically": true
            }
        }
    }
  },
  "joke-prod":{
    "host": "http://localhost",
    "port": "8080",
    "path": "/",
    "Security": {
      "Auth": {
        "oauth2": {
          "Token URL": "https://dev-lesson.eu.auth0.com/oauth/token",
          "Client ID": "2GSRAJdfhRYURWjwlnYwJlJN4J9cEi4o",
          "Grant Type": "Client Credentials",
          "Audience": "chuck-norris-api",
          "Client Secret": "{{clientSecret}}",
          "Type": "OAuth2",
          "Custom Request Parameters": {
            "audience": {
              "Value": "chuck-norris-api",
              "Use": "In Token Request"
            }
          }
        }
      }
    }
  }
}